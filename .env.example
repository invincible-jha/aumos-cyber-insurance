# AumOS Cyber Insurance — Environment Variables
# Copy to .env and fill in values for local development.
# NEVER commit .env to version control.

# ---- AumOS Common (required) ----
AUMOS_DATABASE_URL=postgresql+asyncpg://aumos:aumos@localhost:5432/aumos_cyber_insurance
AUMOS_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
AUMOS_SECRET_KEY=change-me-in-production
AUMOS_DEBUG=true

# ---- Cyber Insurance specific (AUMOS_INSURANCE_ prefix) ----
AUMOS_INSURANCE_RISK_SCORE_MODEL_URL=http://localhost:8030
AUMOS_INSURANCE_RISK_MODEL_TIMEOUT_SECONDS=30.0
AUMOS_INSURANCE_RISK_SCORE_CACHE_TTL_SECONDS=3600

AUMOS_INSURANCE_SYNTHETIC_DATA_URL=http://localhost:8003
AUMOS_INSURANCE_OPTIMIZATION_SAMPLE_SIZE=10000
AUMOS_INSURANCE_PREMIUM_DISCOUNT_CAP_PCT=35.0

AUMOS_INSURANCE_EVIDENCE_PACKAGE_EXPIRY_DAYS=90
AUMOS_INSURANCE_EVIDENCE_STORAGE_BUCKET=aumos-cyber-insurance-evidence

AUMOS_INSURANCE_CARRIER_API_TIMEOUT_SECONDS=15.0
AUMOS_INSURANCE_CARRIER_DATA_REFRESH_HOURS=24

AUMOS_INSURANCE_HTTP_TIMEOUT=30.0
AUMOS_INSURANCE_HTTP_MAX_RETRIES=3
